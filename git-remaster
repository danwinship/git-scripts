#!/bin/sh

# Usage:
#
# git remaster [args] [branch]
#
# Rebases the indicated branch (or the current branch) on top of the
# latest version of origin/master (or origin/main) (updating
# master/main as well along the way). Additional arguments get passed
# to "git rebase", so in particular you can do "git remaster -i".

rev=$(git rev-parse --symbolic --revs-only "$@")
args=$(git rev-parse --flags --sq "$@")

if [ -z "$rev" ]; then
    branch=$(git symbolic-ref HEAD)
    branch=${branch##refs/heads/}
else
    branch="$rev"
fi

if [ -z "$branch" ]; then
    echo "Could not determine branch" 1>&2
    exit 1
fi

git fetch --prune origin || exit $?

master_name=$(git master-name)

master=$(git rev-parse ${master_name})
origin_master=$(git rev-parse origin/${master_name})
if [ $master != $origin_master ]; then
    (git checkout ${master_name} &&
     git pull &&
     git checkout $branch) || exit $?
fi

git rebase $args ${master_name}
